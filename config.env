# ╔══════════════════════════════╗
# ║    👻 GHOST BOT — CONFIG     ║
# ╚══════════════════════════════╝

# ── Bot Settings ──────────────────────────
BOT_NAME=GHOST
PREFIX=.
OWNER_NUMBER=94XXXXXXXXX

# ── Session (pair code generate kalama labena) ──
# Render/Railway eke SESSION_ID environment variable widiyata danna
SESSION_ID=

# ── APIs (Optional) ───────────────────────
# OpenAI key (.ai command walata)
OPENAI_KEY=

# OpenWeatherMap key (optional — key natha wttr.in use karanawa)
WEATHER_API=

# ── Bot Behavior ──────────────────────────
AUTO_READ=true
AUTO_TYPING=true
PUBLIC_MODE=true
MAX_DL_SIZE=100

# ── Server Port (Render auto set karanawa) ─
PORT=3000
